<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Royal Watches | متجر ساعات فاخر</title>
<meta name="description" content="أفضل متجر ساعات فاخر في مصر - خصومات حصرية ودفع عند الاستلام">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
:root{
--gold:#d4af37;
--dark:#0f0f0f;
--card:#1c1c1c;
--gray:#aaa;
}

body{
margin:0;
font-family:'Tahoma',sans-serif;
background:var(--dark);
color:#fff;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:15px 40px;
background:#000;
position:sticky;
top:0;
z-index:1000;
}

.logo{
color:var(--gold);
font-size:22px;
font-weight:bold;
}

nav a{
color:white;
margin:0 10px;
text-decoration:none;
font-size:14px;
}

.hero{
text-align:center;
padding:120px 20px;
background:url("https://images.unsplash.com/photo-1524592094714-0f0654e20314") center/cover;
}

.hero h1{font-size:50px;margin-bottom:10px;}
.hero button{
padding:14px 30px;
background:var(--gold);
border:none;
cursor:pointer;
font-weight:bold;
font-size:16px;
}

section{padding:60px 40px;text-align:center;}

.controls{
display:flex;
justify-content:center;
gap:15px;
flex-wrap:wrap;
margin-bottom:30px;
}

input,select{
padding:8px;
border:none;
border-radius:4px;
}

.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
}

.product{
background:var(--card);
padding:15px;
border-radius:12px;
transition:0.3s;
cursor:pointer;
box-shadow:0 0 15px rgba(0,0,0,0.5);
}

.product:hover{
transform:translateY(-5px);
}

.product img{
width:100%;
height:230px;
object-fit:cover;
border-radius:10px;
}

.price{margin-top:8px;}

.old-price{
text-decoration:line-through;
color:var(--gray);
font-size:14px;
}

.new-price{
color:var(--gold);
font-weight:bold;
font-size:18px;
}

button{
background:var(--gold);
border:none;
padding:10px;
cursor:pointer;
font-weight:bold;
margin-top:10px;
border-radius:6px;
}

.cart{
position:fixed;
top:0;
right:-100%;
width:360px;
height:100%;
background:#1a1a1a;
padding:20px;
transition:0.4s;
overflow:auto;
z-index:2000;
}

.cart.active{right:0;}

footer{
background:#000;
padding:20px;
text-align:center;
}

.social i{
margin:10px;
font-size:20px;
cursor:pointer;
}

/* WhatsApp Button */
.whatsapp-float{
position:fixed;
bottom:20px;
left:20px;
background:#25D366;
color:white;
width:60px;
height:60px;
border-radius:50%;
display:flex;
justify-content:center;
align-items:center;
font-size:30px;
box-shadow:0 0 15px rgba(0,0,0,0.4);
z-index:3000;
transition:0.3s;
text-decoration:none;
}

.whatsapp-float:hover{
transform:scale(1.1);
}
</style>
</head>

<body>

<header>
<div class="logo">Royal Watches</div>
<nav>
<a href="#">الرئيسية</a>
<a href="#shop">المتجر</a>
<a href="#" onclick="openCart()">🛒 <span id="cart-count">0</span></a>
</nav>
</header>

<section class="hero">
<h1>الفخامة تبدأ من معصمك</h1>
<p>اكتشف أحدث الإصدارات بخصومات حصرية</p>
<button onclick="scrollToShop()">تسوق الآن</button>
</section>

<section id="shop">
<h2>المتجر</h2>

<div class="controls">
<input type="text" placeholder="ابحث عن ساعة..." onkeyup="searchProduct(this.value)">
<select onchange="filterPrice(this.value)">
<option value="all">كل الأسعار</option>
<option value="1000">أقل من 1000</option>
<option value="3000">أقل من 3000</option>
</select>
</div>

<div class="products" id="products"></div>
</section>

<footer>
<p>© 2026 Royal Watches</p>
<div class="social">
<i class="fab fa-facebook"></i>
<i class="fab fa-instagram"></i>
<i class="fab fa-whatsapp"></i>
</div>
</footer>

<!-- Cart -->
<div class="cart" id="cart">
<h3>سلة المشتريات</h3>
<div id="cart-items"></div>
<input type="text" id="coupon" placeholder="كود الخصم">
<button onclick="applyCoupon()">تطبيق الكوبون</button>
<h4 id="total"></h4>
<button onclick="checkout()">إتمام الطلب (الدفع عند الاستلام)</button>
<button onclick="closeCart()">إغلاق</button>
</div>

<!-- WhatsApp Button -->
<a href="https://wa.me/201014436943?text=مرحباً، أريد الاستفسار عن الساعات المتاحة" target="_blank" class="whatsapp-float">
<i class="fab fa-whatsapp"></i>
</a>

<script>
let products=[
{id:1,name:"ساعة كلاسيك",price:800,old:950,img:"https://images.unsplash.com/photo-1518546305927-5a555bb7020d"},
{id:2,name:"ساعة جلد",price:1000,old:1200,img:"https://images.unsplash.com/photo-1523275335684-37898b6baf30"},
{id:3,name:"ساعة رياضية",price:600,old:750,img:"https://images.unsplash.com/photo-1547996160-81dfa63595aa"},
{id:4,name:"ساعة ذهبية",price:1200,old:1500,img:"https://images.unsplash.com/photo-1516574187841-cb9cc2ca948b"},
{id:5,name:"ساعة سويسري",price:3000,old:3500,img:"https://images.unsplash.com/photo-1509048191080-d2984bad6ae5"},
{id:6,name:"ساعة بريميوم",price:2100,old:2500,img:"https://images.unsplash.com/photo-1519744346363-d90bdbbafeb2"},
{id:7,name:"ساعة ألماس",price:4000,old:4500,img:"https://images.unsplash.com/photo-1517841905240-472988babdf9"},
{id:8,name:"ساعة إصدار محدود",price:5200,old:6000,img:"https://images.unsplash.com/photo-1484704849700-f032a568e944"}
];

let cart=JSON.parse(localStorage.getItem("cart"))||[];
let discount=0;

function displayProducts(list){
let container=document.getElementById("products");
container.innerHTML="";
list.forEach(p=>{
container.innerHTML+=`
<div class="product">
<img src="${p.img}">
<h3>${p.name}</h3>
<div class="price">
<span class="old-price">${p.old} جنيه</span><br>
<span class="new-price">${p.price} جنيه</span>
</div>
<p>⭐⭐⭐⭐☆</p>
<button onclick="addToCart(${p.id})">إضافة للسلة</button>
</div>`;
});
}

function addToCart(id){
let product=products.find(p=>p.id===id);
cart.push(product);
localStorage.setItem("cart",JSON.stringify(cart));
updateCart();
}

function updateCart(){
document.getElementById("cart-count").innerText=cart.length;
let items="",total=0;
cart.forEach(p=>{
items+=`<p>${p.name} - ${p.price} جنيه</p>`;
total+=p.price;
});
total=total-discount;
document.getElementById("cart-items").innerHTML=items;
document.getElementById("total").innerText="الإجمالي: "+total+" جنيه";
}

function applyCoupon(){
let code=document.getElementById("coupon").value;
if(code==="ROYAL10"){
discount=200;
alert("تم تطبيق خصم 200 جنيه");
}else{
discount=0;
alert("كود غير صالح");
}
updateCart();
}

function checkout(){
alert("تم استلام طلبك وسيتم التواصل معك لتأكيد الدفع عند الاستلام.");
cart=[];
discount=0;
localStorage.removeItem("cart");
updateCart();
closeCart();
}

function openCart(){document.getElementById("cart").classList.add("active");}
function closeCart(){document.getElementById("cart").classList.remove("active");}

function searchProduct(value){
let filtered=products.filter(p=>p.name.includes(value));
displayProducts(filtered);
}

function filterPrice(value){
if(value==="all"){displayProducts(products);}
else{
let filtered=products.filter(p=>p.price<=value);
displayProducts(filtered);
}
}

function scrollToShop(){
document.getElementById("shop").scrollIntoView({behavior:"smooth"});
}

displayProducts(products);
updateCart();
</script>

</body>
</html>
